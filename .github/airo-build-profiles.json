        "flutter_image_compress",
        "flutter_tts",
        "package_info_plus",
        "pdfx",
        "wakelock_plus"
      ],
      "requiredDependencyOverrides": {
        "stockfish": "../packages/stubs/stockfish_stub",
        "chess": "../packages/stubs/chess_stub",
        "flame": "../packages/stubs/flame_stub",
        "google_mlkit_text_recognition": "../packages/stubs/mlkit_stub",
        "just_audio": "../packages/stubs/just_audio_stub",
        "audioplayers": "../packages/stubs/audioplayers_stub",
        "flutter_tts": "../packages/stubs/flutter_tts_stub",
        "image_picker": "../packages/stubs/image_picker_stub",
        "file_picker": "../packages/stubs/file_picker_stub",
        "share_plus": "../packages/stubs/share_plus_stub",
        "flutter_image_compress": "../packages/stubs/flutter_image_compress_stub",
        "flutter_contacts": "../packages/stubs/flutter_contacts_stub",
        "permission_handler": "../packages/stubs/permission_handler_stub",
        "flutter_local_notifications": "../packages/stubs/flutter_local_notifications_stub",
        "timezone": "../packages/stubs/timezone_stub",
        "pdfx": "../packages/stubs/pdfx_stub",
        "package_info_plus": "../packages/stubs/package_info_plus_stub",
        "wakelock_plus": "../packages/stubs/wakelock_plus_stub",
        "flutter_chrome_cast": "../packages/platform_player/third_party/flutter_chrome_cast"
      },
      "assetAllowlist": ["assets/airo_icon.png"],
      "android": {
        "apkArtifact": "app-arm64-v8a-release.apk",
        "abiStrategy": "single-arm64-apk",
        "releaseBudgetMb": 35,
        "debugBudgetMb": 650,
        "enforceReleaseBudget": true
      },
      "macos": {
        "appName": "Airo TV",
        "bundleId": "com.developerscoffee.airo.tv",
        "artifactZip": "Airo-TV-macOS.zip",
        "artifactDmg": "Airo-TV-macOS.dmg",
        "distribution": ["github-release", "homebrew-cask"],
        "signing": "optional-developer-id",
        "notarization": "optional-required-for-public-direct-download"
      }
    },
    {
      "id": "ios-spm",
      "releaseLine": "v2",
      "description": "iOS Swift Package Manager dependency profile.",
      "entrypoint": "app/lib/main.dart",
      "pubspec": "app/pubspec_ios_spm.yaml",
      "appId": "com.developerscoffee.airo",
      "appVariant": "full",
      "appPlatform": "ios",
      "ciBuild": false,
      "edgeProfile": false,
      "requiredPackages": ["airo"],
      "featureModules": ["airo", "feature_coin"],
      "allowedNativePlugins": ["*"],
      "heavyPackages": [],
      "requiredDependencyOverrides": {
        "flutter_chrome_cast": "../packages/platform_player/third_party/flutter_chrome_cast"
      },
      "assetAllowlist": []
    },
    {
      "id": "web-validation",
      "releaseLine": "v2",
      "description": "Local browser validation profile for IPTV UI/data debugging.",
      "entrypoint": "app/lib/main_airo_iptv.dart",
      "pubspec": "app/pubspec.yaml",
      "appId": "web",
      "appVariant": "iptv",
      "appPlatform": "webIptv",
      "ciBuild": false,
      "edgeProfile": false,
      "requiredPackages": ["feature_iptv"],
      "featureModules": ["feature_iptv"],
      "allowedNativePlugins": [],
      "heavyPackages": [],
      "requiredDependencyOverrides": {
        "flutter_chrome_cast": "../packages/platform_player/third_party/flutter_chrome_cast"
      },
      "assetAllowlist": [],
      "web": {
        "requiresCorsPlaylistServer": true,
        "buildMode": "profile"
      }
