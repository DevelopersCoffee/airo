      "platformAppIds": {
        "android": "io.airo.app.tv",
        "macos": "com.developerscoffee.airo.tv"
      },
      "appVariant": "tv",
      "appPlatform": "androidTv",
      "ciBuild": true,
      "edgeProfile": true,
      "requiredPackages": ["airo", "audio_service"],
      "featureModules": ["feature_iptv"],
      "allowedNativePlugins": [
        "audio_service",
        "flutter_chrome_cast",
        "path_provider",
        "shared_preferences",
        "video_player",
        "wakelock_plus"
      ],
      "heavyPackages": [
        "stockfish",
        "chess",
        "flame",
        "google_mlkit_text_recognition",
        "just_audio",
        "audioplayers",
        "flutter_tts",
        "image_picker",
        "file_picker",
        "share_plus",
        "flutter_image_compress",
        "flutter_contacts",
        "permission_handler",
        "flutter_local_notifications",
        "timezone",
        "pdfx"
      ],
